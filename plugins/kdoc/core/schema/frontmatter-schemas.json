{
  "description": "Frontmatter field definitions per document type. Consumed by kdoc doctor and governance scripts.",
  "version": "1",
  "field_values": {
    "security-tier": ["public", "standard", "internal", "elevated", "confidential", "critical"],
    "horizon": ["now", "next", "later", "backlog"],
    "estimated_effort": ["S", "M", "L", "XL"],
    "source": ["manual", "workshop", "discovery", "imported"]
  },
  "types": {
    "adr": {
      "required": ["type", "id", "status", "date", "summary"],
      "optional": ["superseded-by", "supersedes", "open-questions-status", "linear", "tags", "security-tier"],
      "status_values": ["proposed", "accepted", "deprecated", "superseded"],
      "id_pattern": "^ADR-\\d{4}$"
    },
    "feature": {
      "required": ["type", "area", "id", "status", "summary"],
      "optional": ["linear", "tags", "module_path", "package_path", "core_paths", "api_paths", "security-tier"],
      "status_values": ["draft", "in_progress", "ready", "done", "blocked", "deprecated"],
      "gap_tracking_tags": [
        "has-open-questions",
        "missing-test-scenarios",
        "missing-acceptance-criteria",
        "blocked-by-decision"
      ]
    },
    "phase": {
      "required": ["type", "area", "id", "status", "summary"],
      "optional": ["depends_on", "last_reviewed", "sub_phases", "work_units_total", "next_work_units", "tags", "security-tier", "horizon", "outcome", "success_metrics", "estimated_effort", "source", "source_ref", "started_at", "completed_at", "workshop_refs", "pr_refs"],
      "status_values": ["pending", "in_progress", "completed", "completed_with_notes", "blocked"]
    },
    "sub-phase": {
      "required": ["type", "area", "id", "parent_phase", "status", "summary"],
      "optional": ["blocked_by", "parallel_with", "tags", "security-tier"],
      "status_values": ["pending", "in_progress", "completed", "completed_with_notes", "blocked"]
    },
    "runbook": {
      "required": ["type", "status", "summary"],
      "optional": ["owner", "linear", "tags"],
      "status_values": ["draft", "active", "deprecated"]
    },
    "threat-model": {
      "required": ["type", "area", "id", "status", "summary"],
      "optional": ["linear", "tags", "security-tier"],
      "status_values": ["draft", "reviewed", "approved"]
    },
    "reference": {
      "required": ["type", "area", "id", "status", "summary"],
      "optional": ["linear", "tags"]
    },
    "tldr": {
      "required": ["type", "id", "status", "date", "summary"],
      "optional": ["area", "tags", "linear", "module_path", "package_path", "core_paths", "api_paths", "security-tier", "intent"],
      "status_values": ["draft", "in_progress", "ready", "done", "blocked", "deprecated"]
    },
    "index": {
      "required": ["type", "id", "status", "summary"],
      "optional": ["area", "linear", "tags"]
    },
    "context-pack": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "date", "scope", "tags", "aliases", "intent"],
      "status_values": ["draft", "generated", "ready"]
    },
    "guide": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "area", "id", "date", "scope", "tags", "aliases", "intent", "owner"],
      "status_values": ["draft", "active", "deprecated"]
    },
    "flow-spec": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "id", "date", "scope", "tags", "aliases", "security-tier"],
      "status_values": ["draft", "in_progress", "ready", "done", "deprecated"]
    },
    "test-map": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "id", "date", "scope", "tags", "aliases", "intent"],
      "status_values": ["draft", "active", "deprecated"]
    },
    "category-index": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "area", "date", "scope", "category", "tags", "aliases", "intent"],
      "status_values": ["draft", "active"]
    },
    "memory": {
      "required": ["type", "summary"],
      "optional": ["tags"]
    },
    "page-spec": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "app", "id", "date", "tags", "security-tier"],
      "status_values": ["draft", "in_progress", "ready", "done", "deprecated"]
    },
    "screen-spec": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "pack", "screen", "id", "date", "owner", "tags", "security-tier"],
      "status_values": ["draft", "in_progress", "ready", "done", "deprecated"]
    },
    "route-contract": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "module", "id", "date", "tags", "security-tier"],
      "status_values": ["draft", "active", "deprecated"]
    },
    "api-contract": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "pack", "endpoint", "id", "date", "owner", "tags", "security-tier"],
      "status_values": ["draft", "active", "deprecated"]
    },
    "recipe": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "category", "id", "date", "tags"],
      "status_values": ["draft", "active", "deprecated"]
    },
    "design-standard": {
      "required": ["type", "status", "summary"],
      "optional": ["title", "id", "tags"],
      "status_values": ["draft", "active", "deprecated"]
    }
  }
}
